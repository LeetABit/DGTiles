####################################################################
# Editor configuration file
####################################################################
root = true

# Deep indentation code files
[*.{gitattributes,gitignore,editorconfig,md}]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = urf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{js,mjs,ts,tsx}]
indent_style = space
indent_size = 4
end_of_line = lf
charset = urf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Shallow indentation code files
[*.{yml,json,html,css,lock,svg,bicep,env,development}]
indent_style = space
indent_size = 2
end_of_line = crlf
charset = urf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Raw text files
[*.txt]
indent_style = tab
tab_width = 4
end_of_line = crlf
charset = urf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{ico,png}]
