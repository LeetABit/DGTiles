{
  "$schema": "https://json.schemastore.org/package",
  "name": "leetabit.dgtiles",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "cfg": "yarn list && tsc --showConfig && eslint --print-config ./src/index.tsx",
    "clean": "rm -rf ./dist",
    "lint": "tsc --build && eslint . --max-warnings=0 --flag unstable_ts_config && prettier . --check",
    "fix": "eslint . --flag unstable_ts_config --fix && prettier . --write",
    "test": "vitest",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "verify": "yarn clean && yarn lint && vitest run && yarn build"
  },
  "dependencies": {
    "@emotion/react": "11.13.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.28.0"
  },
  "devDependencies": {
    "@axe-core/react": "4.10.1",
    "@eslint/js": "9.13.0",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@types/eslint-config-prettier": "6.11.3",
    "@types/eslint-plugin-react-refresh": "0.4.0",
    "@types/eslint__js": "8.42.3",
    "@types/node": "22.9.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-basic-ssl": "1.1.0",
    "@vitejs/plugin-react-swc": "3.5.0",
    "editorconfig": "2.0.0",
    "eslint": "9.13.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-react": "7.37.2",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-react-refresh": "0.4.14",
    "globals": "15.11.0",
    "jiti": "2.4.0",
    "jsdom": "25.0.1",
    "minimatch": "10.0.1",
    "prettier": "3.3.3",
    "typescript": "5.6.2",
    "typescript-eslint": "8.11.0",
    "vite": "5.4.10",
    "vitest": "2.1.5",
    "vitest-axe": "1.0.0-pre.3"
  }
}
