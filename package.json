{
  "$schema": "https://json.schemastore.org/package",
  "name": "leetabit.dgtiles",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "cfg": "yarn list && tsc --showConfig && eslint --print-config ./src/index.tsx",
    "clean": "rm -rf ./dist",
    "lint": "yarn lint_ts && yarn lint_es",
    "lint_ts": "tsc --build",
    "lint_es": "eslint . --max-warnings=0 --flag unstable_ts_config && prettier . --check",
    "fix": "yarn fix_es && yarn fix_prettier",
    "fix_es": "eslint . --flag unstable_ts_config --fix",
    "fix_prettier": "prettier . --write",
    "test": "vitest",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "verify": "yarn clean && yarn lint && vitest run && yarn build"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router-dom": "7.0.2"
  },
  "devDependencies": {
    "@axe-core/react": "4.10.1",
    "@eslint/js": "9.16.0",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/eslint-config-prettier": "6.11.3",
    "@types/eslint-plugin-react-refresh": "0.4.0",
    "@types/eslint__js": "8.42.3",
    "@types/node": "22.10.2",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.2",
    "@vitejs/plugin-basic-ssl": "1.2.0",
    "@vitejs/plugin-react-swc": "3.7.2",
    "editorconfig": "2.0.0",
    "eslint": "9.16.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-react": "7.37.2",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-react-refresh": "0.4.16",
    "globals": "15.13.0",
    "jiti": "2.4.1",
    "jsdom": "25.0.1",
    "license-checker-rseidelsohn": "4.4.2",
    "minimatch": "10.0.1",
    "parse-package-name": "1.0.0",
    "prettier": "3.4.2",
    "rollup": "4.28.1",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.0",
    "vite": "6.0.3",
    "vitest": "2.1.8",
    "vitest-axe": "1.0.0-pre.3"
  }
}
