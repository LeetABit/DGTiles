{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387

  // TODO: simplify or divide this configuration
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Direct: Chrome",
      "request": "launch",
      "type": "chrome",
      "url": "https://localhost:5000",
      "webRoot": "${workspaceFolder}/src",
      "cascadeTerminateToConfigurations": ["Direct: Server"],
      "presentation": {
          "hidden": true,
      },
      // TODO: check this options
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      },
    },
    {
      "name": "Preview: Chrome",
      "request": "launch",
      "type": "chrome",
      "url": "https://localhost:5000",
      "webRoot": "${workspaceFolder}/src",
      "cascadeTerminateToConfigurations": ["Direct: Server"],
      "presentation": {
          "hidden": true,
      },
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      },
    },
    {
      "name": "Emulator: Chrome",
      "request": "launch",
      "type": "chrome",
      "url": "https://localhost:5001",
      "webRoot": "${workspaceFolder}/src",
      "cascadeTerminateToConfigurations": ["Emulator: Server"],
      "presentation": {
          "hidden": true,
      },
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      },
    },
    {
      "name": "Direct: Server",
      "request": "launch",
      "type": "node-terminal",
      "cwd": "${workspaceFolder}",
      "command": "yarn dev",
      "presentation": {
          "hidden": true,
      },
    },
    {
      "name": "Preview: Server",
      "request": "launch",
      "type": "node-terminal",
      "cwd": "${workspaceFolder}",
      "command": "yarn build && yarn preview",
      "presentation": {
          "hidden": true,
      },
    },
    {
      "name": "Emulator: Server",
      "request": "launch",
      "type": "node-terminal",
      "cwd": "${workspaceFolder}",
      "command": "swa start",
      "presentation": {
          "hidden": true,
      },
    },
    {
      "name": "Build",
      "request": "launch",
      "type": "node-terminal",
      "cwd": "${workspaceFolder}",
      "command": "yarn build",
    },
  ],
  "compounds": [
    {
      "name": "Direct",
      "configurations": [
        "Direct: Server",
        "Direct: Chrome",
      ],
      "stopAll": true,
    },
    {
      "name": "Emulator",
      "configurations": [
        "Emulator: Server",
        "Emulator: Chrome",
      ],
      "stopAll": true,
    },
    {
      "name": "Preview",
      "configurations": [
        "Preview: Server",
        "Preview: Chrome",
      ],
      "stopAll": true,
    }
  ]
}
