{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387

  "version": "0.2.0",
  "configurations": [
    {
      "name": "Chrome",
      "request": "launch",
      "type": "chrome",
      "url": "https://localhost:5000",
      "webRoot": "${workspaceFolder}/src",
      "cascadeTerminateToConfigurations": ["Vite: Dev", "Vite: Preview", "SWA: Start"],
      "presentation": {
          "hidden": true,
      },
    },
    {
      "name": "Vite: Test",
      "request": "launch",
      "type": "node-terminal",
      "cwd": "${workspaceFolder}",
      "command": "yarn test",
      "presentation": {
          "hidden": true,
      },
    },
    {
      "name": "Vite: Dev",
      "request": "launch",
      "type": "node-terminal",
      "cwd": "${workspaceFolder}",
      "command": "yarn dev",
      "presentation": {
          "hidden": true,
      },
    },
    {
      "name": "Vite: Preview",
      "request": "launch",
      "type": "node-terminal",
      "cwd": "${workspaceFolder}",
      "command": "yarn build && yarn preview",
      "presentation": {
          "hidden": true,
      },
    },
    {
      "name": "SWA: Start",
      "request": "launch",
      "type": "node-terminal",
      "cwd": "${workspaceFolder}",
      "command": "swa start",
      "presentation": {
          "hidden": true,
      },
    },
  ],
  "compounds": [
    {
      "name": "Dev",
      "configurations": [
        "Vite: Dev",
        "Chrome",
      ],
    },
    {
      "name": "Preview",
      "configurations": [
        "Vite: Preview",
        "Chrome",
      ],
    },
    {
      "name": "Emulator",
      "configurations": [
        "SWA: Start",
        "Chrome",
      ],
    },
    {
      "name": "Test",
      "configurations": [
        "Vite: Test",
      ],
    },
  ],
}
